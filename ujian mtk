// ===== STATE =====
let allRecords = [];
let currentStudent = null;
let currentQ = 0;
let studentAnswers = new Array(TOTAL_QUESTIONS).fill(-1);
let timerInterval = null;
let timeLeft = EXAM_TIME;
let violationCount = 0;
let examActive = false;

// ===== SDK =====
const defaultConfig = {
  exam_title: 'UJIAN AKHIR SEKOLAH',
  school_name: 'SMPN SATU ATAP TUBAKI',
  subject_name: 'MATEMATIKA',
  background_color: '#87CEEB',
  surface_color: '#FFFFFF',
  text_color: '#1F2937',
  primary_action_color: '#2563EB',
  secondary_action_color: '#059669',
  font_family: 'Poppins',
  font_size: 16
};

const dataHandler = {
  onDataChanged(data) {
    allRecords = data;
    renderGuruTable();
  }
};

async function initApp() {
  await window.dataSdk.init(dataHandler);
  window.elementSdk.init({
    defaultConfig,
    onConfigChange: async (config) => {
      const c = Object.assign({}, defaultConfig, config);
      const el = (id) => document.getElementById(id);
      if (el('h-exam-title')) el('h-exam-title').textContent = c.exam_title;
      if (el('h-school-name')) el('h-school-name').textContent = c.school_name;
      if (el('h-subject')) el('h-subject').innerHTML = 'MATA PELAJARAN : <span id="subject-value">' + c.subject_name + '</span>';
      document.querySelectorAll('.sky-bg').forEach(e => {
        e.style.background = `linear-gradient(180deg, ${c.background_color} 0%, ${lighten(c.background_color, 40)} 60%, ${lighten(c.background_color, 60)} 100%)`;
      });
      document.querySelectorAll('.glass-card').forEach(e => {
        e.style.background = `rgba(${hexToRgb(c.surface_color)}, 0.85)`;
      });
      document.body.style.fontFamily = `${c.font_family}, Poppins, sans-serif`;
      document.body.style.color = c.text_color;
      document.body.style.fontSize = c.font_size + 'px';
    },
    mapToCapabilities: (config) => {
      const c = Object.assign({}, defaultConfig, config);
      const mut = (key) => ({
        get: () => c[key] || defaultConfig[key],
        set: (v) => { c[key] = v; window.elementSdk.setConfig({[key]: v}); }
      });
      return {
        recolorables: [mut('background_color'), mut('surface_color'), mut('text_color'), mut('primary_action_color'), mut('secondary_action_color')],
        borderables: [],
        fontEditable: mut('font_family'),
        fontSizeable: mut('font_size')
      };
    },
    mapToEditPanelValues: (config) => {
      const c = Object.assign({}, defaultConfig, config);
      return new Map([
        ['exam_title', c.exam_title],
        ['school_name', c.school_name],
        ['subject_name', c.subject_name]
      ]);
    }
  });
  populateStudentSelect();
}
initApp();

function hexToRgb(hex) {
  const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
  return `${r},${g},${b}`;
}
function lighten(hex, pct) {
  let r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
  r = Math.min(255, r + Math.round((255-r)*pct/100));
  g = Math.min(255, g + Math.round((255-g)*pct/100));
  b = Math.min(255, b + Math.round((255-b)*pct/100));
  return `#${r.toString(16).padStart(2,'0')}${g.toString(16).padStart(2,'0')}${b.toString(16).padStart(2,'0')}`;
}

// ===== SCREENS =====
function showScreen(id) {
  ['screen-mode','screen-login-guru','screen-login-siswa','screen-exam','screen-result','screen-guru'].forEach(s => {
    document.getElementById(s).classList.add('hidden');
    document.getElementById(s).classList.remove('flex');
  });
