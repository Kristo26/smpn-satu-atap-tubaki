// ===== LOGIN =====
function loginGuru(e) {
  e.preventDefault();
  const p = document.getElementById('guru-pass').value;
  if (p === GURU_PASS) {
    document.getElementById('guru-pass').value = '';
    showScreen('screen-guru');
  } else {
    showToast('Password Anda salah!');
  }
}

function loginSiswa(e) {
  e.preventDefault();
  const name = document.getElementById('siswa-name').value;
  const pass = document.getElementById('siswa-pass').value;
  if (!name) { showToast('Pilih nama terlebih dahulu!'); return; }
  if (pass !== SISWA_PASS) { showToast('Password Anda salah!'); return; }
  // Check if locked/completed
  const rec = allRecords.find(r => r.student_name === name);
  if (rec && (rec.completed || rec.locked)) {
    showToast('Anda sudah menyelesaikan ujian dan tidak dapat login kembali!', 'warning');
    return;
  }
  currentStudent = name;
  document.getElementById('siswa-pass').value = '';
  startExam(rec);
}

// ===== EXAM =====
function startExam(existingRecord) {
  examActive = true;
  violationCount = 0;
  currentQ = 0;
  studentAnswers = new Array(TOTAL_QUESTIONS).fill(-1);
  // Restore answers if exists
  if (existingRecord && existingRecord.answers) {
    try {
      const saved = JSON.parse(existingRecord.answers);
      if (Array.isArray(saved)) studentAnswers = saved;
    } catch(e) {}
  }
  timeLeft = EXAM_TIME;
  document.getElementById('exam-student-name').textContent = currentStudent;
  document.getElementById('violation-badge').classList.add('hidden');
  document.getElementById('violation-count').textContent = '0';
  showScreen('screen-exam');
  renderNavButtons();
  renderQuestion();
  startTimer();
  setupAntiCheat();
}

function renderNavButtons() {
  const c = document.getElementById('nav-buttons');
  c.innerHTML = '';
  for (let i = 0; i < TOTAL_QUESTIONS; i++) {
    const b = document.createElement('button');
    b.textContent = i + 1;
    b.className = `w-8 h-8 rounded-lg text-xs font-bold transition-all ${i === currentQ ? 'bg-blue-600 text-white' : studentAnswers[i] >= 0 ? 'bg-green-500 text-white' : 'bg-white text-gray-600 border border-gray-200 hover:bg-gray-50'}`;
    b.onclick = () => { currentQ = i; renderQuestion(); renderNavButtons(); };
    c.appendChild(b);
  }
}

function renderQuestion() {
  const q = QUESTIONS[currentQ];
  const area = document.getElementById('question-area');
  let imageHtml = '';
  if (q.image) {
    imageHtml = `<div class="mb-4 bg-gray-50 rounded-lg p-3 text-center"><img src="${q.image}" alt="Gambar soal ${currentQ + 1}" loading="lazy" class="max-w-full h-auto rounded-lg mx-auto" onerror="console.error('Image failed:',this.src);this.style.background='#e5e7eb';this.alt='Gambar tidak dapat ditampilkan';"></div>`;
  }
  area.innerHTML = `
    <p class="text-xs text-gray-400 mb-1 font-semibold">Soal ${currentQ + 1} dari ${TOTAL_QUESTIONS}</p>
    <p class="text-gray-800 font-medium mb-4 whitespace-pre-line">${escHtml(q.text)}</p>
    ${imageHtml}
    <div class="space-y-2">
      ${q.options.map((o, i) => `
        <button onclick="selectAnswer(${i})" class="option-btn w-full text-left px-4 py-3 rounded-xl flex items-center gap-3 ${studentAnswers[currentQ] === i ? 'selected' : ''}">
          <span class="w-8 h-8 rounded-full ${studentAnswers[currentQ] === i ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-600'} flex items-center justify-center font-bold text-sm flex-shrink-0">${String.fromCharCode(65+i)}</span>
          <span class="text-sm">${escHtml(o)}</span>
        </button>
      `).join('')}
    </div>
  `;
  document.getElementById('btn-prev').style.visibility = currentQ > 0 ? 'visible' : 'hidden';
  document.getElementById('btn-next').textContent = currentQ < TOTAL_QUESTIONS - 1 ? 'Selanjutnya' : '';
  lucide.createIcons();
}

function escHtml(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

function selectAnswer(idx) {
  studentAnswers[currentQ] = idx;
  renderQuestion();
  renderNavButtons();
}

function navigateQ(dir) {
  const next = currentQ + dir;
  if (next >= 0 && next < TOTAL_QUESTIONS) {
    currentQ = next;
    renderQuestion();
    renderNavButtons();
  }
}

// ===== TIMER =====
function startTimer() {
  clearInterval(timerInterval);
  updateTimerDisplay();
  timerInterval = setInterval(() => {
    timeLeft--;
    updateTimerDisplay();
    if (timeLeft <= 0) {
      clearInterval(timerInterval);
      autoSubmit('Waktu habis!');
    }
  }, 1000);
}

function updateTimerDisplay() {
  const m = Math.floor(timeLeft / 60);
  const s = timeLeft % 60;
  const txt = document.getElementById('timer-text');
  txt.textContent = `${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
  const td = document.getElementById('timer-display');
  if (timeLeft <= 300) {
    td.classList.remove('bg-blue-600');
    td.classList.add('bg-red-500', 'timer-warning');
  } else {
    td.classList.add('bg-blue-600');
    td.classList.remove('bg-red-500', 'timer-warning');
  }
}

// ===== ANTI-CHEAT =====
function setupAntiCheat() {
  window._visHandler = () => {
    if (!examActive) return;
    if (document.hidden) {
      violationCount++;
      document.getElementById('violation-badge').classList.remove('hidden');
      document.getElementById('violation-count').textContent = violationCount;
      if (violationCount >= 5) {
        autoSubmit('Anda terdeteksi membuka tab lain lebih dari 5 kali. Ujian ditutup otomatis.');
      } else {
        showToast(`Peringatan! Jangan tinggalkan halaman ujian. (${violationCount}/5)`, 'warning');
      }
    }
  };
  window._copyHandler = (e) => {
    if (!examActive) return;
    e.preventDefault();
    violationCount++;
    document.getElementById('violation-badge').classList.remove('hidden');
    document.getElementById('violation-count').textContent = violationCount;
    if (violationCount >= 5) {
      autoSubmit('Anda terdeteksi melakukan copy/paste lebih dari 5 kali. Ujian ditutup otomatis.');
    } else {
      showToast(`Copy/Paste tidak diizinkan! (${violationCount}/5)`, 'warning');
    }
  };
  document.addEventListener('visibilitychange', window._visHandler);
  document.addEventListener('copy', window._copyHandler);
  document.addEventListener('paste', window._copyHandler);
  document.addEventListener('cut', window._copyHandler);
}

function cleanupAntiCheat() {
  if (window._visHandler) document.removeEventListener('visibilitychange', window._visHandler);
  if (window._copyHandler) {
    document.removeEventListener('copy', window._copyHandler);
    document.removeEventListener('paste', window._copyHandler);
    document.removeEventListener('cut', window._copyHandler);
  }
}

// ===== FINISH EXAM =====
function confirmFinish() {
  const answered = studentAnswers.filter(a => a >= 0).length;
  document.getElementById('answered-count').textContent = answered;
  document.getElementById('screen-confirm-finish').classList.remove('hidden');
}
function hideConfirmFinish() {
  document.getElementById('screen-confirm-finish').classList.add('hidden');
}

async function autoSubmit(reason) {
  examActive = false;
  cleanupAntiCheat();
  clearInterval(timerInterval);
  showToast(reason, 'warning');
  await saveResults(true);
}

async function finishExam() {
  hideConfirmFinish();
  examActive = false;
  cleanupAntiCheat();
  clearInterval(timerInterval);
  await saveResults(false);
}

async function saveResults(locked) {
  let correct = 0, wrong = 0;
  for (let i = 0; i < TOTAL_QUESTIONS; i++) {
    if (studentAnswers[i] >= 0) {
      if (studentAnswers[i] === QUESTIONS[i].answer) correct++;
      else wrong++;
    }
  }
  const totalScore = (correct * SCORE_PER_CORRECT);
  const nilai = Math.round((totalScore / MAX_SCORE) * 100 * 100) / 100;

  const existing = allRecords.find(r => r.student_name === currentStudent);
  const data = {
    student_name: currentStudent,
    answers: JSON.stringify(studentAnswers),
    correct_count: correct,
    wrong_count: wrong,
    score: nilai,
    completed: true,
    locked: locked,
    violation_count: violationCount,
    submitted_at: new Date().toISOString()
  };

  let result;
  if (existing) {
    result = await window.dataSdk.update({...existing, ...data});
  } else {
    if (allRecords.length >= 999) { showToast('Batas data tercapai!', 'warning'); return; }
    result = await window.dataSdk.create(data);
  }

  if (!result.isOk) { showToast('Gagal menyimpan data!'); }

  // Show result
  document.getElementById('result-name').textContent = currentStudent;
  document.getElementById('result-correct').textContent = correct;
  document.getElementById('result-wrong').textContent = wrong;
  document.getElementById('result-score').textContent = nilai;
  showScreen('screen-result');
}

function logoutSiswa() {
  currentStudent = null;
  showScreen('screen-mode');
}

function logoutGuru() {
  showScreen('screen-mode');
}

// ===== GURU TABLE =====
function renderGuruTable() {
  const tbody = document.getElementById('guru-table-body');
  if (!tbody) return;
  tbody.innerHTML = '';
  const sorted = [...STUDENTS].sort();
  sorted.forEach((name, idx) => {
    const rec = allRecords.find(r => r.student_name === name);
    const tr = document.createElement('tr');
    tr.className = idx % 2 === 0 ? 'bg-white' : 'bg-gray-50';
    tr.innerHTML = `
      <td class="px-3 py-2">${idx + 1}</td>
      <td class="px-3 py-2 font-medium">${escHtml(name)}</td>
      <td class="px-3 py-2 text-center">
        ${rec && rec.completed ? '<span class="bg-green-100 text-green-700 text-xs font-bold px-2 py-1 rounded-full">Selesai</span>' : rec && rec.locked ? '<span class="bg-red-100 text-red-600 text-xs font-bold px-2 py-1 rounded-full">Terkunci</span>' : '<span class="bg-gray-100 text-gray-500 text-xs font-bold px-2 py-1 rounded-full">Belum</span>'}
      </td>
      <td class="px-3 py-2 text-center font-bold ${rec ? 'text-green-600' : 'text-gray-300'}">${rec ? rec.correct_count : '-'}</td>
      <td class="px-3 py-2 text-center font-bold ${rec ? 'text-red-500' : 'text-gray-300'}">${rec ? rec.wrong_count : '-'}</td>
      <td class="px-3 py-2 text-center font-bold ${rec ? 'text-blue-600' : 'text-gray-300'}">${rec ? rec.score : '-'}</td>
      <td class="px-3 py-2 text-center no-print">
        <div class="flex gap-1 justify-center">
          ${rec && rec.completed ? `<button onclick="showDetail('${escAttr(name)}')" class="bg-blue-50 hover:bg-blue-100 text-blue-600 px-2 py-1 rounded-lg text-xs font-semibold">Detail</button>` : ''}
          ${rec ? `<button onclick="confirmResetStudent('${escAttr(name)}')" class="bg-red-50 hover:bg-red-100 text-red-600 px-2 py-1 rounded-lg text-xs font-semibold">Reset</button>` : ''}
        </div>
      </td>
    `;
    tbody.appendChild(tr);
  });
}

function escAttr(s) { return s.replace(/'/g, "\\'").replace(/"/g, '&quot;'); }

// Detail
function showDetail(name) {
  const rec = allRecords.find(r => r.student_name === name);
  if (!rec) return;
  document.getElementById('detail-title').textContent = `Detail Jawaban: ${name}`;
  let answers = [];
  try { answers = JSON.parse(rec.answers); } catch(e) {}
  let html = `<div class="mb-3 grid grid-cols-3 gap-2 text-sm">
    <div class="bg-green-50 rounded-lg p-2 text-center"><span class="font-bold text-green-600">${rec.correct_count}</span><br><span class="text-xs text-gray-500">Benar</span></div>
    <div class="bg-red-50 rounded-lg p-2 text-center"><span class="font-bold text-red-500">${rec.wrong_count}</span><br><span class="text-xs text-gray-500">Salah</span></div>
    <div class="bg-blue-50 rounded-lg p-2 text-center"><span class="font-bold text-blue-600">${rec.score}</span><br><span class="text-xs text-gray-500">Nilai</span></div>
  </div>`;
  if (rec.violation_count > 0) {
    html += `<div class="bg-yellow-50 border border-yellow-200 rounded-lg p-2 mb-3 text-xs text-yellow-700">⚠️ Pelanggaran: ${rec.violation_count} kali</div>`;
  }
  html += '<div class="space-y-1 max-h-96 overflow-auto">';
  for (let i = 0; i < TOTAL_QUESTIONS; i++) {
    const a = answers[i] ?? -1;
    const correct = QUESTIONS[i].answer;
    const isCorrect = a === correct;
    const notAnswered = a < 0;
    html += `<div class="flex items-center gap-2 text-xs px-2 py-1 rounded ${isCorrect ? 'bg-green-50' : notAnswered ? 'bg-gray-50' : 'bg-red-50'}">
      <span class="font-bold w-6">${i+1}.</span>
      <span class="flex-1">Jawaban: ${notAnswered ? '-' : String.fromCharCode(65 + a)}</span>
      <span class="text-gray-400">Kunci: ${String.fromCharCode(65 + correct)}</span>
      <span class="${isCorrect ? 'text-green-600' : notAnswered ? 'text-gray-400' : 'text-red-500'} font-bold">${isCorrect ? '✓' : notAnswered ? '-' : '✗'}</span>
    </div>`;
  }
  html += '</div>';
  document.getElementById('detail-content').innerHTML = html;
  document.getElementById('detail-modal').classList.remove('hidden');
  lucide.createIcons();
}

// Reset
let resetTargetName = null;
function confirmResetStudent(name) {
  resetTargetName = name;
  const rec = allRecords.find(r => r.student_name === name);
  if (rec) {
    // Inline confirm via toast-like approach - just do it with a second click pattern
    resetStudent(name);
  }
}

async function resetStudent(name) {
  const rec = allRecords.find(r => r.student_name === name);
  if (!rec) return;
  const result = await window.dataSdk.delete(rec);
  if (result.isOk) {
    showToast(`Data ${name} berhasil direset.`, 'success');
  } else {
    showToast('Gagal mereset data!');
  }
}

function resetAllConfirm() {
  document.getElementById('reset-all-confirm').classList.remove('hidden');
}

async function resetAll() {
  document.getElementById('reset-all-confirm').classList.add('hidden');
  for (const rec of [...allRecords]) {
    await window.dataSdk.delete(rec);
  }
  showToast('Semua data siswa berhasil direset.', 'success');
}

// Print
function printDaftarNilai() {
  window.print();
}

